# TRI-LAYER INTELLIGENCE - ENVIRONMENT VAULT
# ==========================================

# Kafka Message Broker
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Elasticsearch Database
# Your native install has security enabled (HTTPS + login), unlike the
# old docker-compose setup which had xpack.security.enabled=false.
ELASTICSEARCH_URL=https://localhost:9200
ELASTIC_USERNAME=elastic
elasticsearch-reset-password.bat -u elastic

# Tor Network Configuration
# 9150 = Tor Browser's bundled proxy (confirmed running on your machine).
# 9050 = standalone Tor service/daemon default, if you switch to that instead.
TOR_PROXY_URL=socks5h://127.0.0.1:9150

# Shared export folder used by both the orchestrator (reads files for the
# download button) and the pipeline (writes scraped files here). Must match.
EXPORT_DIR=exports

# AI / LLM Configuration (For the normalizer)
# Leave blank or use a mock string if you are just testing locally
OPENAI_API_KEY=your_actual_api_key_goes_here
